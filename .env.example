# Variables d'environnement rubitrack — copier vers .env (gitignoré) et adapter.
# En production, TOUTES les valeurs sensibles doivent être définies ici
# (les valeurs par défaut de settings.py ne servent qu'au dev local).

# Django
DJANGO_SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
RUBITRACK_DB_NAME=rubitrack_dev
RUBITRACK_DB_USER=rubi
RUBITRACK_DB_PASSWORD=changez-moi
RUBITRACK_DB_HOST=localhost
RUBITRACK_DB_PORT=5432

# Logging (DEBUG, INFO, WARNING, ERROR)
RUBITRACK_LOG_LEVEL=INFO
